# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vila_fi

# JWT — deve ter pelo menos 32 caracteres
JWT_SECRET=substitua_por_um_segredo_aleatorio_com_no_minimo_32_chars
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL da app (sem barra no final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Freesound API — só servidor, NÃO use o prefixo NEXT_PUBLIC_ senão o token
# vaza no bundle do navegador. Obtenha gratuitamente em:
# https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=sua_chave_aqui
